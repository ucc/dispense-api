#!/usr/bin/env bash
set -euo pipefail

# Load .env if present
if [[ -f "$(dirname "$0")/../.env" ]]; then
  set -a; source "$(dirname "$0")/../.env"; set +a
fi

CLIENT_ID="${OIDC_CLIENT_ID:-dispense-api}"
CLIENT_SECRET="${OIDC_CLIENT_SECRET:?Set OIDC_CLIENT_SECRET in .env or environment}"
TOKEN_URL="${OIDC_ISSUER_URI:-https://keycloak.ucc.asn.au/realms/master}/protocol/openid-connect/token"

read -rp "Username: " user
read -rsp "Password: " pass
echo >&2

curl -sf -X POST "$TOKEN_URL" \
  -d "grant_type=password" \
  -d "client_id=$CLIENT_ID" \
  -d "client_secret=$CLIENT_SECRET" \
  -d "username=$user" \
  -d "password=$pass" \
  -d "scope=openid" | jq -r '.access_token'
